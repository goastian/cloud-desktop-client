{
  "name": "astian-cloud-desktop",
  "version": "1.0.2",
  "description": "Astian Cloud Desktop Sync Client",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev:renderer": "cd src/renderer-vue && npm run dev",
    "dev:electron": "electron . --dev",
    "dev": "concurrently -n vue,electron \"npm run dev:renderer\" \"npm run dev:electron\"",
    "build:renderer": "cd src/renderer-vue && npm run build",
    "prebuild": "npm run build:renderer",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder -mwl"
  },
  "keywords": [
    "astian",
    "cloud",
    "sync",
    "desktop"
  ],
  "author": {
    "name": "Astian",
    "email": "contact@astian.org"
  },
  "homepage": "https://astian.org",
  "license": "AGPL-3.0",
  "dependencies": {
    "axios": "1.6.0",
    "chokidar": "3.5.3",
    "conf": "10.1.2",
    "form-data": "4.0.0",
    "uuid": "^9.0.0",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "39.8.4",
    "electron-builder": "24.6.4"
  },
  "build": {
    "appId": "com.astian.cloud.desktop",
    "productName": "Astian Cloud",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main/**/*",
      "dist-renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-renderer",
        "to": "dist-renderer"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "assets/icon.png",
      "maintainer": "Astian <info@astian.org>"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "goastian",
        "repo": "cloud-desktop-client"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
